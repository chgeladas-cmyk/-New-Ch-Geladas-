rules_version = '2';

/**
 * CH Geladas PDV — Firestore Security Rules v3
 * ─────────────────────────────────────────────────────────────────────
 *
 * COLEÇÕES E PERMISSÕES
 * ┌─────────────────────┬────────────────────┬──────────────────────────────┐
 * │  Coleção            │  Leitura           │  Escrita                     │
 * ├─────────────────────┼────────────────────┼──────────────────────────────┤
 * │  ch_dados/estoque   │  PDV + ADM         │  ADM (adminToken)            │
 * │  ch_dados/config    │  PDV + ADM         │  ADM (adminToken)            │
 * │  ch_dados/categorias│  PDV + ADM         │  ADM (adminToken)            │
 * │  ch_dados/*outros*  │  ADM               │  ADM (adminToken)            │
 * │  vendas/{id}        │  ADM               │  PDV + ADM                   │
 * │  movimentacoes/{id} │  ADM               │  ADM + sistema (transaction) │
 * │  categorias/{id}    │  PDV + ADM         │  ADM                         │
 * │  fornecedores/{id}  │  ADM               │  ADM                         │
 * │  backups/{data}/**  │  ADM               │  ADM (adminToken)            │
 * └─────────────────────┴────────────────────┴──────────────────────────────┘
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ───────────────────────────────────────────

    function autenticado() {
      return request.auth != null;
    }

    function docValido(data) {
      return data.keys().hasAll(['dados', 'ts'])
          && data.ts is string
          && data.ts.size() > 0;
    }

    function temAdminToken(data) {
      return data.keys().hasAny(['adminToken'])
          && data.adminToken is string
          && data.adminToken.size() == 64; // FIX #6: SHA-256 tem exatamente 64 chars
    }

    function vendaValida(data) {
      return data.keys().hasAll(['id', 'total', 'itens', 'criadoEm'])
          && data.total is number
          && data.itens is list;
    }

    function movimentacaoValida(data) {
      return data.keys().hasAll(['produtoId', 'tipo', 'quantidade', 'timestamp'])
          && data.quantidade is number;
    }

    // Coleções abertas para leitura por qualquer autenticado (PDV + ADM)
    function colecaoPublica(colecao) {
      return colecao in ['estoque', 'config', 'categorias'];
    }

    // ─── /ch_dados/comandas — qualquer autenticado pode escrever ────
    // Comandas são criadas por colaboradores/operadores sem adminToken
    match /ch_dados/comandas {
      allow read:  if autenticado();
      allow write: if autenticado() && docValido(request.resource.data);
    }

    // ─── /ch_dados/fiado — qualquer autenticado pode escrever ───────
    match /ch_dados/fiado {
      allow read:  if autenticado();
      allow write: if autenticado() && docValido(request.resource.data);
    }

    // ─── /ch_dados/cambio — qualquer autenticado pode escrever ──────
    match /ch_dados/cambio {
      allow read:  if autenticado();
      allow write: if autenticado() && docValido(request.resource.data);
    }

    // ─── /ch_dados/ponto — qualquer autenticado pode escrever ───────
    // Ponto é registrado por colaboradores sem adminToken.
    // Controle de edição/cancelamento é feito no app (admin only).
    match /ch_dados/ponto {
      allow read:  if autenticado();
      allow write: if autenticado() && docValido(request.resource.data);
    }

    // ─── /ch_dados/perfis — qualquer autenticado pode ler, admin escreve ──
    match /ch_dados/perfis {
      allow read:  if autenticado();
      allow write: if autenticado() && docValido(request.resource.data) && temAdminToken(request.resource.data);
    }

    // ─── /ch_dados/{colecao} ─────────────────────────────────────────
    match /ch_dados/{colecao} {

      // Leitura: qualquer autenticado pode ler qualquer coleção.
      // O controle de acesso por role é feito no app (SyncService.pull filtra por role).
      // request.resource.data não existe em leituras — não pode ser usado aqui.
      allow read: if autenticado();

      // Escrita: exige adminToken e documento válido
      allow write: if autenticado()
                   && docValido(request.resource.data)
                   && temAdminToken(request.resource.data);
    }

    // ─── /vendas/{vendaId} ───────────────────────────────────────────
    // create: PDV e colaboradores (sem adminToken)
    // update: qualquer autenticado (aprovação/validação pelo controlador/validador)
    // delete: apenas admin (adminToken obrigatório)
    match /vendas/{vendaId} {
      allow create: if autenticado() && vendaValida(request.resource.data);
      allow read:   if autenticado();
      allow update: if autenticado();
      allow delete: if autenticado() && temAdminToken(request.resource.data);
    }

    // ─── /movimentacoes/{movId} ──────────────────────────────────────
    match /movimentacoes/{movId} {
      allow create: if autenticado() && movimentacaoValida(request.resource.data);
      allow read:   if autenticado();
      allow update, delete: if autenticado()
                             && temAdminToken(request.resource.data);
    }

    // ─── /categorias/{catId} ─────────────────────────────────────────
    match /categorias/{catId} {
      allow read:  if autenticado();
      allow write: if autenticado() && temAdminToken(request.resource.data);
    }

    // ─── /fornecedores/{fornId} ──────────────────────────────────────
    match /fornecedores/{fornId} {
      allow read:  if autenticado();
      allow write: if autenticado() && temAdminToken(request.resource.data);
    }

    // ─── /backups/{data}/snapshots/{snapshotId} ──────────────────────
    // Backup automático diário — apenas admin escreve e lê
    match /backups/{data}/snapshots/{snapshotId} {
      // Leitura: autenticado é suficiente (dados sensíveis já são sanitizados pelo BackupService)
      allow read:  if autenticado();
      // Escrita: exige adminToken (apenas admin pode gerar backups)
      allow write: if autenticado() && temAdminToken(request.resource.data);
    }

    // ─── /ch_dados/usuarios — lista de usuarios sincronizada ────────
    // Usuarios podem ser lidos por qualquer autenticado.
    // Escrita exige adminToken (apenas admin cria/edita usuarios).
    // Override da regra geral /ch_dados/{colecao} para explicitar.
    // (A regra geral ja cobre, mas deixamos explícito para clareza.)

    // ─── SaaS: empresas, usuários, convites ─────────────────────────
    // FIX #7: Isolamento multi-tenant SaaS
    // Cada empresa só acessa os próprios dados.
    // Requer custom claim 'empresaId' no Firebase Auth (setear via Cloud Function no login).
    match /saas_empresas/{empresaId} {
      allow read:  if autenticado() && request.auth.token.empresaId == empresaId;
      allow write: if autenticado() && request.auth.token.empresaId == empresaId
                   && request.auth.token.role == 'dono';
    }

    match /saas_usuarios/{uid} {
      // Usuário lê/edita apenas próprio perfil; dono lê todos da sua empresa
      allow read:  if autenticado() && (request.auth.uid == uid
                   || request.auth.token.role == 'dono');
      allow write: if autenticado() && request.auth.uid == uid;
    }

    match /saas_convites/{codigo} {
      allow read:  if autenticado();
      allow write: if autenticado() && request.auth.token.role == 'dono';
    }

    match /saas_dados/{empresaId}/{colecao}/{docId} {
      // FIX #7: isolamento cross-tenant — só acessa dados da própria empresa
      allow read, write: if autenticado()
                         && request.auth.token.empresaId == empresaId;
    }

    // ─── /ch_tripwire/{docId} — Log imutável de intrusões ────────────
    // Qualquer autenticado (incluindo PDV anônimo) pode CRIAR.
    // Ninguém pode atualizar ou deletar — nem o admin via console.
    match /ch_tripwire/{docId} {
      allow create: if autenticado();
      allow read:   if autenticado();
      allow update, delete: if false;
    }

    // ─── Bloqueia tudo que não foi mapeado ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
