rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }
    function docValido(data) {
      return data.keys().hasAll(['dados', 'ts'])
          && data.ts is string && data.ts.size() > 0;
    }
    function temAdminToken(data) {
      return data.keys().hasAny(['adminToken'])
          && data.adminToken is string
          && data.adminToken.size() >= 16;
    }
    function vendaValida(data) {
      return data.keys().hasAll(['id', 'total', 'itens', 'criadoEm'])
          && data.total is number && data.itens is list;
    }

    // ── PDV standalone (sem SaaS) ───────────────────────────────────
    match /ch_dados/{colecao} {
      allow read:  if autenticado();
      allow write: if autenticado()
                   && docValido(request.resource.data)
                   && temAdminToken(request.resource.data);
    }
    match /vendas/{vendaId} {
      allow create: if autenticado() && vendaValida(request.resource.data);
      allow read:   if autenticado();
      allow update, delete: if autenticado() && temAdminToken(request.resource.data);
    }
    match /movimentacoes/{movId} {
      allow create: if autenticado();
      allow read:   if autenticado();
      allow update, delete: if autenticado() && temAdminToken(request.resource.data);
    }
    match /backups/{data}/snapshots/{snapshotId} {
      allow read:  if autenticado();
      allow write: if autenticado() && temAdminToken(request.resource.data);
    }

    // ── SaaS: metadados ────────────────────────────────────────────
    match /saas_empresas/{empresaId} {
      allow read, write: if autenticado();
    }
    match /saas_usuarios/{uid} {
      allow read, write: if autenticado();
    }
    match /saas_convites/{codigo} {
      allow read, write: if autenticado();
    }

    // ── SaaS: dados isolados por empresa ───────────────────────────
    match /saas_dados/{empresaId}/ch_dados/{colecao} {
      allow read:  if autenticado();
      allow write: if autenticado()
                   && docValido(request.resource.data)
                   && temAdminToken(request.resource.data);
    }
    match /saas_dados/{empresaId}/vendas/{vendaId} {
      allow create: if autenticado() && vendaValida(request.resource.data);
      allow read:   if autenticado();
      allow update, delete: if autenticado() && temAdminToken(request.resource.data);
    }
    match /saas_dados/{empresaId}/movimentacoes/{movId} {
      allow create: if autenticado();
      allow read:   if autenticado();
      allow update, delete: if autenticado() && temAdminToken(request.resource.data);
    }
    match /saas_dados/{empresaId}/backups/{data}/snapshots/{snapshotId} {
      allow read:  if autenticado();
      allow write: if autenticado() && temAdminToken(request.resource.data);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
